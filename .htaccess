# ── Security headers ────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options            "nosniff"
    Header always set X-Frame-Options                   "DENY"
    Header always set Referrer-Policy                   "strict-origin-when-cross-origin"
    Header always set Permissions-Policy                "geolocation=(), microphone=(), camera=()"
    Header always set Strict-Transport-Security         "max-age=63072000; includeSubDomains"
    Header always set Content-Security-Policy           "default-src 'self'; script-src 'self' 'sha256-0CcKsY49q+QPM5JuwYJRbLzDg1qPO/qPc+rmWY6FDQ8='; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src https://api.github.com; frame-ancestors 'none'; base-uri 'self'; form-action 'none'"
</IfModule>
